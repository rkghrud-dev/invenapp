<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="16dp"
        android:paddingRight="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_tinted"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_title"
                android:textColor="?attr/paletteTextPrimary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_subtitle"
                android:textColor="?attr/paletteTextSecondary"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_primary"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/options_google_title"
                android:textColor="?attr/paletteTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/options_google_summary"
                android:textColor="?attr/paletteTextSecondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/google_status_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_status_chip"
                android:paddingLeft="14dp"
                android:paddingTop="10dp"
                android:paddingRight="14dp"
                android:paddingBottom="10dp"
                android:textColor="?attr/paletteTextPrimary"
                android:textSize="14sp" />

            <Button
                android:id="@+id/google_connect_button"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/options_google_button"
                android:textAllCaps="false"
                android:textColor="?attr/paletteTextPrimary"
                android:textSize="16sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_primary"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_tools_title"
                android:textColor="?attr/paletteTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/admin_tools_summary"
                android:textColor="?attr/paletteTextSecondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/admin_mode_title"
                        android:textColor="?attr/paletteTextPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/admin_mode_summary"
                        android:textColor="?attr/paletteTextSecondary"
                        android:textSize="13sp" />

                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/admin_mode_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:showText="false" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/admin_tools_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_tools_note"
                    android:textColor="?attr/paletteTextSecondary"
                    android:textSize="14sp" />

                <TextView style="@style/FormLabel" android:layout_marginTop="18dp" android:text="@string/label_ranking_spreadsheet_id" />
                <EditText android:id="@+id/ranking_spreadsheet_id_input" style="@style/FormInput" android:hint="@string/hint_spreadsheet_id" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_reminder_title"
                            android:textColor="?attr/paletteTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/admin_reminder_summary"
                            android:textColor="?attr/paletteTextSecondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/admin_reminder_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:showText="false" />

                </LinearLayout>

                <TextView style="@style/FormLabel" android:layout_marginTop="18dp" android:text="@string/label_reminder_time" />

                <EditText
                    android:id="@+id/reminder_time_input"
                    style="@style/FormInput"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:drawableEnd="@android:drawable/ic_lock_idle_alarm"
                    android:drawablePadding="12dp"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:hint="@string/hint_reminder_time"
                    android:importantForAutofill="no"
                    android:inputType="none" />

                <Button
                    android:id="@+id/data_sync_button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/data_sync_button"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/data_sync_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="?attr/paletteTextSecondary"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card_primary"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_note"
                android:textColor="?attr/paletteTextSecondary"
                android:textSize="14sp" />

            <TextView style="@style/FormLabel" android:layout_marginTop="18dp" android:text="@string/label_spreadsheet_id" />
            <EditText android:id="@+id/spreadsheet_id_input" style="@style/FormInput" android:hint="@string/hint_spreadsheet_id" />
            <TextView style="@style/FormLabel" android:text="@string/label_range" />
            <EditText android:id="@+id/range_input" style="@style/FormInput" android:hint="@string/hint_range" />
            <TextView style="@style/FormLabel" android:text="@string/label_product_code_column" />
            <EditText android:id="@+id/product_code_column_input" style="@style/FormInput" android:hint="@string/hint_column" />
            <TextView style="@style/FormLabel" android:text="@string/label_order_code_column" />
            <EditText android:id="@+id/order_code_column_input" style="@style/FormInput" android:hint="@string/hint_column_optional" />
            <TextView style="@style/FormLabel" android:text="@string/label_product_name_column" />
            <EditText android:id="@+id/product_name_column_input" style="@style/FormInput" android:hint="@string/hint_column_optional" />
            <TextView style="@style/FormLabel" android:text="@string/label_stock_column" />
            <EditText android:id="@+id/stock_column_input" style="@style/FormInput" android:hint="@string/hint_column" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/settings_sales_note"
                android:textColor="?attr/paletteTextSecondary"
                android:textSize="14sp" />

            <TextView style="@style/FormLabel" android:layout_marginTop="18dp" android:text="@string/label_sales_spreadsheet_id" />
            <EditText android:id="@+id/sales_spreadsheet_id_input" style="@style/FormInput" android:hint="@string/hint_spreadsheet_id" />
            <TextView style="@style/FormLabel" android:text="@string/label_sales_range" />
            <EditText android:id="@+id/sales_range_input" style="@style/FormInput" android:hint="@string/hint_sales_range" />
            <TextView style="@style/FormLabel" android:text="@string/label_sales_product_code_column" />
            <EditText android:id="@+id/sales_product_code_column_input" style="@style/FormInput" android:hint="@string/hint_column" />
            <TextView style="@style/FormLabel" android:text="@string/label_sales_quantity_column" />
            <EditText android:id="@+id/sales_quantity_column_input" style="@style/FormInput" android:hint="@string/hint_column" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/example_button"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:text="@string/example_button"
                    android:textAllCaps="false"
                    android:textColor="?attr/paletteTextPrimary"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/save_button"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginLeft="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/save_button"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/save_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="?attr/paletteTextSecondary"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
