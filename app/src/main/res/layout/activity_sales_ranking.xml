<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:paddingLeft="20dp"
    android:paddingTop="24dp"
    android:paddingRight="20dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_tinted"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sales_ranking_title"
            android:textColor="?attr/paletteTextPrimary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sales_ranking_subtitle"
            android:textColor="?attr/paletteTextSecondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/query_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_status_chip"
            android:paddingLeft="14dp"
            android:paddingTop="10dp"
            android:paddingRight="14dp"
            android:paddingBottom="10dp"
            android:textColor="?attr/paletteTextPrimary"
            android:textSize="13sp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_primary"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ranking_filter_title"
            android:textColor="?attr/paletteTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/top10_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="@string/ranking_top10"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/top30_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/ranking_top30"
                android:textAllCaps="false"
                android:textColor="?attr/paletteTextPrimary" />

            <Button
                android:id="@+id/top50_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginLeft="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/ranking_top50"
                android:textAllCaps="false"
                android:textColor="?attr/paletteTextPrimary" />

        </LinearLayout>

        <Button
            android:id="@+id/today_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/ranking_today_button"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/date_picker_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:gravity="start|center_vertical"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:text="@string/ranking_select_date_button"
                android:textAllCaps="false"
                android:textColor="?attr/paletteTextPrimary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/date_search_button"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginLeft="10dp"
                android:background="@drawable/bg_button_secondary"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:text="@string/ranking_date_button"
                android:textAllCaps="false"
                android:textColor="?attr/paletteTextPrimary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/month_picker_button"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:gravity="start|center_vertical"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:text="@string/ranking_select_month_button"
                android:textAllCaps="false"
                android:textColor="?attr/paletteTextPrimary"
                android:textSize="16sp" />

            <Button
                android:id="@+id/month_search_button"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginLeft="10dp"
                android:background="@drawable/bg_button_secondary"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:text="@string/ranking_month_button"
                android:textAllCaps="false"
                android:textColor="?attr/paletteTextPrimary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="?attr/colorAccent"
                android:visibility="gone" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:textColor="?attr/paletteTextSecondary"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/ranking_results_title"
        android:textColor="?attr/paletteTextPrimary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/results_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/empty_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_primary"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/ranking_empty_results"
        android:textColor="?attr/paletteTextSecondary"
        android:textSize="15sp"
        android:visibility="gone" />

</LinearLayout>
