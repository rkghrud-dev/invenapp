<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.InventoryManager" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/alabaster_grey</item>
        <item name="android:statusBarColor">@color/alabaster_grey</item>
        <item name="android:navigationBarColor">@color/alabaster_grey</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="FormLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">14dp</item>
        <item name="android:textColor">@color/ebony</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="FormInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingTop">15dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:paddingBottom">15dp</item>
        <item name="android:textColor">@color/ebony</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>
